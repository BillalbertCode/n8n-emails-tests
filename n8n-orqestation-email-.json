    {
      "parameters": {
        "jsCode": "const output = [];\nconst items = $input.all()\n\nfor (const item of items) {\n  const titles = item.json.title;\n  const links = item.json.urls;\n  const id_email = item.json.id_email;\n  const from = item.json.headers\n\n  for (let i = 0; i < titles.length; i++) {\n    output.push({\n      json: {\n        title: titles[i],\n        link: links[i],\n        id_email: id_email,\n        from\n      }\n    });\n  }\n}\n\nreturn output;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1664,
        720
      ],
      "id": "b7d45f09-5204-4d4d-84dc-ac259c362be8",
      "name": "Normalizacion"
    },
    {
      "parameters": {
        "jsCode": "const output = [];\nconst regex = /(https:\\/\\/www\\.linkedin\\.com\\/comm\\/jobs\\/view\\/\\d+)/;\nconst items = $input.all()\n\nfor (const item of items) {\n  const textos = item.json.link; // es un array de strings\n\n  const linkedin_urls = textos\n    .map(texto => {\n      const match = texto.match(regex);\n      return match ? match[1] : null;\n    })\n    .filter(url => url !== null); // elimina los nulls (textos sin URL)\n\n  output.push({\n    json: {\n      ...item.json,\n      urls: linkedin_urls\n    }\n  });\n}\n\nreturn output;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        992,
        144
      ],
      "id": "57cf17a0-d29e-40da-a962-cb62ed95d146",
      "name": "Linkedin Links regex"
    },
    {
      "parameters": {
        "jsCode": "const output = [];\nconst regex = /url=(https%3A%2F%2F[^&]+?)(?:%3F|&|$)/;\nconst items = $input.all()\n\nfor (const item of items) {\n  const textos = item.json.link; // es un array de strings\n\n  const computrabajo_urls = textos\n    .map(texto => {\n      const match = texto.match(regex);\n      if (match) {\n        let urlDecodificada = decodeURIComponent(match[1]);\n        // Si la URL tiene parámetros internos, quedarse solo con la parte antes del ?\n        urlDecodificada = urlDecodificada.split('?')[0];\n        return urlDecodificada;\n      }\n      return null;\n    })\n    .filter(url => url !== null);\n\n  output.push({\n    json: {\n      ...item.json,\n      urls: computrabajo_urls\n    }\n  });\n}\n\nreturn output;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        992,
        -48
      ],
      "id": "efb45233-0ac7-4ad1-afb2-80a53057fa08",
      "name": "Computrabajo Links Regex"
