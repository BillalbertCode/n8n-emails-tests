    {
      "parameters": {
        "jsCode": "const output = [];\nconst items = $input.all();\n\nfor (const item of items) {\n  const textos = item.json.link;\n\n  const urls_getonbrd = textos\n    .map(texto => {\n      // Si es link de tracking de AWS\n      if (texto.includes('awstrack.me')) {\n        // Extraer la parte después de \"https:%2F%2Fwww.getonbrd.com\"\n        const start = texto.indexOf('https:%2F%2Fwww.getonbrd.com');\n        if (start !== -1) {\n          let encoded = texto.substring(start);\n          // Cortar antes del '/1/' de tracking\n          const end = encoded.indexOf('/1/');\n          if (end !== -1) {\n            encoded = encoded.substring(0, end);\n          }\n          return decodeURIComponent(encoded);\n        }\n      }\n      return texto;\n    })\n    .filter(url => url !== null);\n\n  output.push({\n    json: {\n      ...item.json,\n      urls: urls_getonbrd\n    }\n  });\n}\n\nreturn output;"
      },
