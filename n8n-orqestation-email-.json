    {
      "parameters": {
        "jsCode": "const output = [];\nconst regex = /(https:\\/\\/www\\.linkedin\\.com\\/comm\\/jobs\\/view\\/\\d+)/;\nconst items = $input.all()\n\nfor (const item of items) {\n  const textos = item.json.link; // es un array de strings\n\n  const linkedin_urls = textos\n    .map(texto => {\n      const match = texto.match(regex);\n      return match ? match[1] : null;\n    })\n    .filter(url => url !== null); // elimina los nulls (textos sin URL)\n\n  output.push({\n    json: {\n      ...item.json,\n      urls: linkedin_urls\n    }\n  });\n}\n\nreturn output;"
      },
