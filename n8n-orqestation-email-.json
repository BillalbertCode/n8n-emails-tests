        "jsCode": "const output = [];\nconst items = $input.all();\n\nfor (const item of items) {\n  const textos = item.json.link;\n\n  // Simplemente pasar los textos originales sin ninguna transformación\n  const urls_originales = textos.filter(url => url !== null && url !== undefined);\n\n  output.push({\n    json: {\n      ...item.json,\n      urls: urls_originales\n    }\n  });\n}\n\nreturn output;"
