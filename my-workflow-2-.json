    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nfor (const item of items) {\n  const email = item.json;\n  \n  let domain = \"desconocido\";\n  const fromAddress = email.from?.value?.[0]?.address || \n                      email.from?.address || \n                      email.from || \n                      \"desconocido\";\n  const atIndex = String(fromAddress).indexOf(\"@\");\n  \n  if (atIndex !== -1) {\n    domain = String(fromAddress).substring(atIndex + 1).trim();\n  }\n  \n  // Hash basado en SUBJECT (no en nombre del remitente)\n  const subjectRaw = String(email.from?.text)\n    .replace(/\\d+/g, \"\")      // quitar números (IDs, fechas, conteos)\n    .replace(/\\s+/g, \"\")      // quitar espacios\n    .substring(0, 40)         // primeros 40 chars ya bastan para identificar\n    .toLowerCase();\n  $input.first().json.from.text\n  const hashInput = domain + \"|\" + subjectRaw;\n  let hash = \"\";\n  for (let i = 0; i < hashInput.length; i++) {\n    const charCode = hashInput.charCodeAt(i);\n    hash += (charCode % 16).toString(16);\n  }\n  \n  email.hash = hash.substring(0, 16);\n  email.fromDomain = domain;\n}\n\nreturn items;"
      },
